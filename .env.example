# ========================================
# CanLah Environment Variables (.env)
# ========================================
#
# Copy this file to .env and customize for your environment.
# Never commit .env to git — it's in .gitignore
#
# See DEPLOYMENT.md and SECRETS_SETUP.md for detailed setup instructions.

# ===== REQUIRED: API Keys =====

# Vercel Blob token (for file storage)
# Get from: https://vercel.com/account/storage
BLOB_READ_WRITE_TOKEN=your_vercel_blob_token_here

# Anthropic API key (for AI analysis)
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Supabase URL (database connection)
# Format: https://your-project-ref.supabase.co
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase Service Role Key (server-side database access)
# ⚠️  KEEP THIS SECRET — never expose in frontend
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here

# ===== REQUIRED: Auth & Security =====

# Login password for web interface
ACCESS_PASSWORD=change-me-for-production

# Session cookie signing secret (random 32+ characters)
# Generate: openssl rand -base64 32
SESSION_SECRET=your_random_32_char_session_secret_here

# ===== OPTIONAL: Configuration =====

# Supabase table name (default: canlah_reports)
SUPABASE_REPORTS_TABLE=canlah_reports

# Node environment (development or production)
NODE_ENV=development

# Demo mode: true = mock data + no real API calls
# Set to false in production
DEMO_MODE=true

# Rate limit: requests per minute per IP (default: 60)
RATE_LIMIT_PER_MIN=60

# ===== OPTIONAL: Error Tracking =====

# Sentry DSN for error reporting
# Get from: https://sentry.io
SENTRY_DSN=

# ===== OPTIONAL: Advanced =====

# Public API key for browser-based uploads (if using separate frontend API)
PUBLIC_API_KEY=

# Admin API key for curl debugging (local only — not used in production)
ADMIN_API_KEY=your_local_admin_api_key_here

# ===== DEVELOPMENT CONVENIENCE =====

# Uncomment below for local testing without real credentials:
# DEMO_MODE=true
# BLOB_READ_WRITE_TOKEN=fake-token
# ANTHROPIC_API_KEY=fake-key


# Login-based access (recommended for prod). Users sign in at /login with this
# password. Without it, /api/process, /api/save-report, /api/reports return 401
# unless DEMO_MODE=true or ADMIN_API_KEY is provided.
ACCESS_PASSWORD=set_a_strong_password_here

# HMAC secret for signing session cookies. Set to a long random string in prod.
# If unset, falls back to ACCESS_PASSWORD (less ideal: rotating the password
# invalidates all sessions).
SESSION_SECRET=set_a_long_random_string_here

# Rate limiting: requests per minute per IP (default 60)
RATE_LIMIT_PER_MIN=60
