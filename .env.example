# Local development example for Vercel Blob and Anthropic API
# Copy this file to .env and set your own values.

# Vercel Blob token — get this from https://vercel.com/account/storage
# Required for production and end-to-end testing
BLOB_READ_WRITE_TOKEN=your_vercel_blob_token_here

# Anthropic API key — get this from https://console.anthropic.com/
# Required for PDF analysis
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Demo mode — set to true to run locally without real credentials
# Uses mock files stored in /tmp/canlah-demo and demo analysis results
DEMO_MODE=true

# Public API key for browser-based uploads and analysis in production
PUBLIC_API_KEY=your_public_api_key_here

# Supabase storage for saved reports
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_key_here
SUPABASE_REPORTS_TABLE=canlah_reports

# Admin API key for back-compat with curl debugging. Sent as x-api-key header.
ADMIN_API_KEY=your_local_admin_api_key_here

# Login-based access (recommended for prod). Users sign in at /login with this
# password. Without it, /api/process, /api/save-report, /api/reports return 401
# unless DEMO_MODE=true or ADMIN_API_KEY is provided.
ACCESS_PASSWORD=set_a_strong_password_here

# HMAC secret for signing session cookies. Set to a long random string in prod.
# If unset, falls back to ACCESS_PASSWORD (less ideal: rotating the password
# invalidates all sessions).
SESSION_SECRET=set_a_long_random_string_here

# Rate limiting: requests per minute per IP (default 60)
RATE_LIMIT_PER_MIN=60
